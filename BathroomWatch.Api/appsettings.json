{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Issuer": "BathroomWatch.Api",
    "Audience": "BathroomWatch.Web",
    "SigningKey": "replace-with-a-long-random-32-char-minimum-secret",
    "ExpirationMinutes": 480
  },
  "Cors": {
    "AllowedOrigins": ["http://localhost:5173"]
  }
}
